# Server
PORT=3000

# Supabase (service_role key — server-side only, never expose client-side)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Meta webhook verification (Phase 1 assumes a single Meta app across tenants;
# per-tenant webhookVerifyToken values in tenant_whatsapp_credentials are used
# once handle_get is called per-tenant in a future phase)
WEBHOOK_VERIFY_TOKEN=

# AI provider fallback router
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_MS=60000
AI_REQUEST_TIMEOUT_MS=15000
CONVERSATION_HISTORY_TURNS=8
TENANT_CACHE_TTL_MS=30000

# Dashboard (Phase 2)
# Comma-separated list of origins allowed to call /api/*. Leave unset in dev.
DASHBOARD_ORIGINS=
