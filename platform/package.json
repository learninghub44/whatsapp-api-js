{
    "name": "whatsapp-platform",
    "version": "0.1.0",
    "private": true,
    "description": "Multi-tenant WhatsApp automation loop with a pluggable multi-AI-provider fallback layer, built on top of whatsapp-api-js. Runs on Cloudflare Workers (see wrangler.toml).",
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "wrangler dev",
        "build": "tsc -p tsconfig.json --noEmit",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "deploy": "wrangler deploy",
        "tail": "wrangler tail"
    },
    "dependencies": {
        "whatsapp-api-js": "workspace:*",
        "@supabase/supabase-js": "^2.45.4",
        "hono": "^4.6.14",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241127.0",
        "@types/node": "^18.19.130",
        "typescript": "^5.9.3",
        "wrangler": "^4.0.0"
    }
}
