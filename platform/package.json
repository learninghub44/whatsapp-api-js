{
    "name": "whatsapp-platform",
    "version": "0.1.0",
    "private": true,
    "description": "Phase 1: multi-tenant WhatsApp automation loop with a pluggable multi-AI-provider fallback layer, built on top of whatsapp-api-js.",
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "whatsapp-api-js": "workspace:*",
        "@supabase/supabase-js": "^2.45.4",
        "express": "^4.19.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/cors": "^2.8.17",
        "@types/node": "^18.19.130",
        "typescript": "^5.9.3",
        "tsx": "^4.19.0"
    }
}
